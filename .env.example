# SmartVision AI — Environment Variables
# Copy this file to .env and fill in your values

# HuggingFace Hub (for model weight storage)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_REPO_ID=your-username/smartvision-models

# FastAPI URL (Docker: http://fastapi:8000 | Local: http://localhost:8000)
FASTAPI_URL=http://localhost:8000

# Airflow Fernet key (required for docker-compose.airflow.yml)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your-generated-fernet-key-here

# Training mode (true = dev subsamples; false = full pipeline)
FAST_MODE=true
