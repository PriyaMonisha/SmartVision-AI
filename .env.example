# SmartVision AI — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git — it is listed in .gitignore.

# ── HuggingFace Hub (for model weight storage) ────────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_REPO_ID=your-username/smartvision-models

# ── FastAPI URL ───────────────────────────────────────────────────────────────
# Docker stack: http://fastapi:8000  |  Local dev: http://localhost:8000
FASTAPI_URL=http://localhost:8000

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave REDIS_PASSWORD empty for local dev (no auth).
# Set a strong password (32+ chars) for production deployments.
REDIS_PASSWORD=

# ── Training mode ─────────────────────────────────────────────────────────────
# true = dev subsamples (fast); false = full pipeline (Docker/production)
FAST_MODE=true

# ── Airflow (only needed for docker-compose.airflow.yml) ──────────────────────
# Generate Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your-generated-fernet-key-here

# Airflow PostgreSQL credentials — CHANGE these in production.
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change-me-in-production

# Airflow web UI admin account — CHANGE in production.
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change-me-in-production
